  "tu_skip": "ދޫކޮށްލުން",
  "tu_next": "ދެން",
  "tu_understood": "ފަހުމްވުން",
  "tu_engine_state": "އިންޖީނު ސްޓޭޓް",
  "tu_engine_state_desc": "މި އައިކޮން އިން ދައްކުވައިދެނީ އެތެރޭގެ ސަރވަރ ތައްޔާރުތޯއެވެ. މައްސަލަތަކެއް ދިމާވެއްޖެނަމަ މިތަނަށް ފިތާލުމުން ގޯސްތައް ބަލާ ނުވަތަ މޮޑިއުލްތައް ޗެކް ކުރާށެވެ.",
  "tu_download": "ކޮންޓެންޓް ޑައުންލޯޑް ކުރާށެވެ",
  "tu_download_desc": "ވީޑިއޯ ނުވަތަ ޕްލޭލިސްޓް ލިންކް މިތަނުގައި ޕޭސްޓް ކުރާށެވެ. ޑައުންލޯޑް ބަޓަން ފިއްތާލުމުން ސެޓިންގްސްގައި ހޮވާފައިވާ ކޮލިޓީއާއި ފޯމެޓް ބޭނުންކުރެވޭނެއެވެ.",
  "tu_filters": "ފިލްޓަރސް އެންޑް ސަރޗް",
  "tu_filters_desc": "މި މެނޫ ފުޅާކޮށް ނަމުން ޑައުންލޯޑްތައް ހޯދުމަށް ނުވަތަ ވަކިވަކި ވީޑިއޯތަކާއި ޕްލޭލިސްޓްތަކުގެ މެދުގައި ފިލްޓަރ ކޮށްލާށެވެ.",
  "tu_settings": "ސެޓިންގސް",
  "tu_settings_desc": "ޑިފޯލްޓް ރިޒޮލިއުޝަންތައް ކޮންފިގްރޭޓް ކުރުމަށް، މެޓަޑޭޓާ އިންޖެކްޓް ކުރުމަށް، ޕްރޮކްސީ ބޭނުން ކުރުމަށް، ނުވަތަ އޮޓޮމެޓިކް ސަބްޓައިޓްލް އިތުރު ކުރުމަށް މިތަނަށް ވަދެވޭނެއެވެ.",
  "tu_settings_categories": "ސެޓިންގސް ކެޓަގަރީސް",
  "tu_settings_categories_desc": "މި ސެޓިންގްސް ބަހާލެވިފައިވަނީ ޖެނެރަލް، ނެޓްވޯކް (ޕްރޮކްސީސް، ކުކީސް)، ވީޑިއޯ (ފޯމެޓްސް، ސަބްޓައިޓަލްސް) އަދި ޑައުންލޯޑް (މަގުތައް، ނަން) އަށެވެ.",
  "tu_settings_search": "ސަރޗް ސެޓިންގސް",
  "tu_settings_search_desc": "ދިހަވަރަކަށް އިޚްތިޔާރު އެބަހުއްޓެވެ. ވަކި އެއްޗެއް ('ޕްރޮކްސީ' ނުވަތަ 'ސަބްޓައިޓަލްސް' ފަދަ) ނުފެނިއްޖެނަމަ، ވަގުތުން ލިސްޓް ފިލްޓަރ ކުރުމަށް ސަރޗް ބާރ ބޭނުން ކުރާށެވެ.",
  "tu_system_details_python_server": "ޕައިތަން ސަރވަރ އެވެ",
  "tu_system_details_python_server_desc": "ވިޑްރާ އިން ޑައުންލޯޑްތައް ޕްރޮސެސް ކުރުމަށް ލޯކަލް ސަރވަރެއް ބޭނުން ކުރެއެވެ. މިތަނުގައި އެކަން ހިނގަމުންދާކަން ޔަގީންކޮށް، ގޯސްތަކެއް ދިމާވެއްޖެނަމަ އޭގެ ލޮގްތައް ޗެކް ކުރެވޭނެއެވެ.",
  "tu_system_details_modules_updates": "މޮޑިއުލްސް އެންޑް އަޕްޑޭޓްސް",
  "tu_system_details_modules_updates_desc": "ސަޕޯޓްކުރާ ޕޭޖްތަކާ އެއްގޮތްކަން ކަށަވަރުކުރުމަށްޓަކައި yt-dlp އަދި އޭގެ ޕެޗްތައް އަޕްޑޭޓްކޮށް ބެހެއްޓުން. އެކްސްޕެރިމެންޓަލް ވާޝަންތައް ހޯދަން ބޭނުންނަމަ ޗެނަލް ބަދަލުކުރެވޭނެ އެވެ.",
