  "tu_engine_state_desc": "ಆಂತರಿಕ ಸರ್ವರ್ ಸಿದ್ಧವಾಗಿದೆಯೇ ಎಂಬುದನ್ನು ಈ ಐಕಾನ್ ಸೂಚಿಸುತ್ತದೆ. ನಿಮಗೆ ಸಮಸ್ಯೆಗಳಿದ್ದರೆ, ದೋಷಗಳನ್ನು ವೀಕ್ಷಿಸಲು ಅಥವಾ ಮಾಡ್ಯೂಲ್‌ಗಳನ್ನು ಪರಿಶೀಲಿಸಲು ಇಲ್ಲಿ ಟ್ಯಾಪ್ ಮಾಡಿ.",
  "tu_download": "ವಿಷಯವನ್ನು ಡೌನ್‌ಲೋಡ್ ಮಾಡಿ",
  "tu_download_desc": "ವೀಡಿಯೊ ಅಥವಾ ಪ್ಲೇಪಟ್ಟಿ ಲಿಂಕ್ ಅನ್ನು ಇಲ್ಲಿ ಅಂಟಿಸಿ. ನೀವು ಡೌನ್‌ಲೋಡ್ ಬಟನ್ ಅನ್ನು ಒತ್ತಿದಾಗ, ನಿಮ್ಮ ಸೆಟ್ಟಿಂಗ್‌ಗಳಲ್ಲಿ ನೀವು ಆಯ್ಕೆ ಮಾಡಿದ ಗುಣಮಟ್ಟ ಮತ್ತು ಸ್ವರೂಪವನ್ನು ಬಳಸಲಾಗುತ್ತದೆ.",
  "tu_filters": "ಶೋಧಕಗಳು ಮತ್ತು ಹುಡುಕಾಟ",
  "tu_filters_desc": "ಹೆಸರಿನ ಮೂಲಕ ಡೌನ್‌ಲೋಡ್‌ಗಳನ್ನು ಹುಡುಕಲು ಈ ಮೆನುವನ್ನು ವಿಸ್ತರಿಸಿ ಅಥವಾ ಪ್ರತ್ಯೇಕ ವೀಡಿಯೊಗಳು ಮತ್ತು ಪ್ಲೇಪಟ್ಟಿಗಳ ನಡುವೆ ಫಿಲ್ಟರ್ ಮಾಡಿ.",
  "tu_settings": "ಸೆಟ್ಟಿಂಗ್‌ಗಳು",
  "tu_settings_desc": "ಡೀಫಾಲ್ಟ್ ರೆಸಲ್ಯೂಶನ್‌ಗಳನ್ನು ಕಾನ್ಫಿಗರ್ ಮಾಡಲು, ಮೆಟಾಡೇಟಾವನ್ನು ಇಂಜೆಕ್ಟ್ ಮಾಡಲು, ಪ್ರಾಕ್ಸಿಗಳನ್ನು ಬಳಸಲು ಅಥವಾ ಸ್ವಯಂಚಾಲಿತ ಉಪಶೀರ್ಷಿಕೆಗಳನ್ನು ಸೇರಿಸಲು ಇಲ್ಲಿ ನಮೂದಿಸಿ.",
  "tu_settings_categories": "ಸೆಟ್ಟಿಂಗ್‌ಗಳ ವರ್ಗಗಳು",
  "tu_settings_categories_desc": "ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಸಾಮಾನ್ಯ, ನೆಟ್‌ವರ್ಕ್ (ಪ್ರಾಕ್ಸಿಗಳು, ಕುಕೀಸ್), ವೀಡಿಯೊ (ಫಾರ್ಮ್‌ಗಳು, ಉಪಶೀರ್ಷಿಕೆಗಳು) ಮತ್ತು ಡೌನ್‌ಲೋಡ್ (ಮಾರ್ಗಗಳು, ಹೆಸರುಗಳು) ಎಂದು ವಿಂಗಡಿಸಲಾಗಿದೆ.",
  "tu_settings_search": "ಹುಡುಕಾಟ ಸೆಟ್ಟಿಂಗ್‌ಗಳು",
  "tu_settings_search_desc": "ಡಜನ್ಗಟ್ಟಲೆ ಆಯ್ಕೆಗಳಿವೆ. ನಿಮಗೆ ನಿರ್ದಿಷ್ಟವಾದುದನ್ನು ('ಪ್ರಾಕ್ಸಿ' ಅಥವಾ 'ಉಪಶೀರ್ಷಿಕೆಗಳು' ನಂತಹ) ಕಂಡುಹಿಡಿಯಲಾಗದಿದ್ದರೆ, ಪಟ್ಟಿಯನ್ನು ತಕ್ಷಣವೇ ಫಿಲ್ಟರ್ ಮಾಡಲು ಹುಡುಕಾಟ ಪಟ್ಟಿಯನ್ನು ಬಳಸಿ.",
  "tu_system_details_python_server": "ಪೈಥಾನ್ ಸರ್ವರ್",
  "tu_system_details_python_server_desc": "ಡೌನ್‌ಲೋಡ್‌ಗಳನ್ನು ಪ್ರಕ್ರಿಯೆಗೊಳಿಸಲು ವಿದ್ರಾ ಸ್ಥಳೀಯ ಸರ್ವರ್ ಅನ್ನು ಬಳಸುತ್ತದೆ. ಇಲ್ಲಿ ನೀವು ಅದು ಚಾಲನೆಯಲ್ಲಿದೆ ಎಂದು ಪರಿಶೀಲಿಸಬಹುದು ಮತ್ತು ದೋಷಗಳ ಸಂದರ್ಭದಲ್ಲಿ ಅದರ ಲಾಗ್‌ಗಳನ್ನು ಪರಿಶೀಲಿಸಬಹುದು.",
  "tu_system_details_modules_updates": "ಮಾಡ್ಯೂಲ್‌ಗಳು ಮತ್ತು ನವೀಕರಣಗಳು",
  "tu_system_details_modules_updates_desc": "ಬೆಂಬಲಿತ ಪುಟಗಳೊಂದಿಗೆ ಹೊಂದಾಣಿಕೆಯನ್ನು ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಲು yt-dlp ಮತ್ತು ಅದರ ಪ್ಯಾಚ್‌ಗಳನ್ನು ನವೀಕರಿಸಿ. ನೀವು ಪ್ರಾಯೋಗಿಕ ಆವೃತ್ತಿಗಳನ್ನು ಹುಡುಕುತ್ತಿದ್ದರೆ ನೀವು ಚಾನಲ್‌ಗಳನ್ನು ಬದಲಾಯಿಸಬಹುದು.",
