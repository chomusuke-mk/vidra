  "tu_engine_state": "I-Engine State",
  "tu_engine_state_desc": "Lesi sithonjana sibonisa ukuthi iseva yangaphakathi isilungile yini. Uma unezinkinga, thepha lapha ukuze ubuke amaphutha noma uhlole amamojula.",
  "tu_download": "Landa Okuqukethwe",
  "tu_download_desc": "Namathisela isixhumanisi sevidiyo noma sohlu lwadlalwayo lapha. Uma ucindezela inkinobho yokukhipha, ikhwalithi nefomethi oyikhethile kuzilungiselelo zakho izosetshenziswa.",
  "tu_filters": "Izihlungi Nosesho",
  "tu_filters_desc": "Nweba le menyu ukuze useshe okulandiwe ngamagama noma ngesihlungi phakathi kwamavidiyo angawodwana nohlu lwadlalwayo.",
  "tu_settings": "Izilungiselelo",
  "tu_settings_desc": "Ngena lapha ukuze ulungiselele ukulungiswa okuzenzakalelayo, ujove imethadatha, usebenzise ama-proxies, noma wengeze imibhalo engezansi ezenzakalelayo.",
  "tu_settings_categories": "Izigaba zezilungiselelo",
  "tu_settings_categories_desc": "Izilungiselelo zihlukaniswe Okujwayelekile, Inethiwekhi (Ama-Proxies, Amakhukhi), Ividiyo (Amafomethi, Imibhalo engezansi) kanye Nokulanda (Izindlela, Amagama).",
  "tu_settings_search": "Sesha Izilungiselelo",
  "tu_settings_search_desc": "Kukhona inqwaba yezinketho. Uma ungakwazi ukuthola okuthile okuqondile (njengokuthi 'Ummeleli' noma 'Imibhalo engezansi'), sebenzisa ibha yokusesha ukuze uhlunge uhlu ngokushesha.",
  "tu_system_details_python_server": "Iseva yePython",
  "tu_system_details_python_server_desc": "I-Vidra isebenzisa iseva yendawo ukucubungula okulandiwe. Lapha ungaqinisekisa ukuthi iyasebenza futhi uhlole amalogi ayo uma kwenzeka kuba namaphutha.",
  "tu_system_details_modules_updates": "Amamojula kanye Izibuyekezo",
  "tu_system_details_modules_updates_desc": "Gcina i-yt-dlp neziqephu zayo zibuyekeziwe ukuze uqinisekise ukuhambisana namakhasi asekelwe. Ungashintsha iziteshi uma ufuna izinguqulo zokuhlola.",
