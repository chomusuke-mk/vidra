  "s_keep_fragments": "Պահպանեք բեկորներ",
  "s_keep_fragments_desc": "Միաձուլվելուց հետո պահում է ներբեռնված հատվածները:",
  "s_force_overwrites": "Ուժի վերագրանցում",
  "s_force_overwrites_desc": "Գոյություն ունեցող ֆայլերը վերագրանցում է առանց հաստատման:\nՄիացված է. «Ռեզյումե» տարբերակը կներբեռնվի սկզբից:\nԱնջատված է. տվյալների բազայի նույնացուցիչը կավելացվի ելքային ձևանմուշի երրորդից վերջին դիրքում:",
  "s_write_thumbnail": "Գրեք մանրապատկեր",
  "s_write_thumbnail_desc": "Պահում է տեսանյութի մանրապատկերը սկավառակի վրա:",
  "s_live_from_start": "Ուղիղ հեռարձակում սկզբից",
