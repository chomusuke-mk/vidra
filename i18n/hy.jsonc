  "s_wait_for_video": "Սպասեք տեսանյութի",
  "s_wait_for_video_desc": "Սպասում է, որ ծրագրված տեսանյութը հասանելի դառնա նախքան ներբեռնելը:",
  "s_mark_watched": "Մարկը դիտեց",
  "s_mark_watched_desc": "Ներբեռնումից հետո նշում է տեսանյութը որպես դիտված:",
  "s_js_runtimes": "JavaScript Runtimes",
