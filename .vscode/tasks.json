{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "$schema": "vscode://schemas/tasks",
  "version": "2.0.0",
  "inputs": [
    {
      "id": "targetPlatform",
      "type": "pickString",
      "description": "Selecciona la plataforma para compilar Serious Python",
      "options": [
        "Android",
        "Windows",
        "Linux",
        "iOS",
        "Darwin",
      ],
      "default": "Android"
    }
  ],
  "tasks": [
    {
      "label": "Flutter: Clean Android (gradlew clean)",
      "type": "shell",
      "command": "./gradlew",
      "args": [
        "clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}/android",
        "env": {
          "SERIOUS_PYTHON_SITE_PACKAGES": "${workspaceFolder}/build/site-packages"
        }
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Serious Python: Package App",
      "type": "process",
      "command": "dart",
      "args": [
        "run",
        "serious_python:main",
        "package",
        "app/src",
        "-r",
        "-r",
        "-r",
        "app/requirements/base.txt",
        "-r",
        "-r",
        "-r",
        "app/requirements/${input:targetPlatform}.txt",
        "-p",
        "${input:targetPlatform}",
        "--verbose",
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "SERIOUS_PYTHON_SITE_PACKAGES": "${workspaceFolder}/build/site-packages",
          "SERIOUS_PYTHON_APP": "${workspaceFolder}/build/app",
        }
      },
      "dependsOn": [
        "Prepare: Create site-packages directory"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Prepare: Create site-packages directory",
      "type": "process",
      "command": "bash",
      "windows": {
        "command": "cmd",
        "args": [
          "/c",
          "if not exist ${workspaceFolder}\\build\\site-packages mkdir ${workspaceFolder}\\build\\site-packages"
        ]
      },
      "args": [
        "-c",
        "mkdir -p \"${workspaceFolder}/build/site-packages\""
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "clear": false
      },
    },
    {
      "label": "Build Android APK (Flutter)",
      "type": "process",
      "command": "flutter",
      "args": [
        "build",
        "apk",
        "--release"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "SERIOUS_PYTHON_SITE_PACKAGES": "${workspaceFolder}/build/site-packages",
          "SERIOUS_PYTHON_APP": "${workspaceFolder}/build/app",
        }
      },
      "dependsOn": [
        "Prepare: Create site-packages directory"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}