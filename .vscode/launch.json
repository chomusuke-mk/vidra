{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "vidra (debug mode)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "env": {
        "SERIOUS_PYTHON_SITE_PACKAGES": "${workspaceFolder}/.serious_python/site-packages",
        "SERIOUS_PYTHON_APP": "${workspaceFolder}/.serious_python/app",
      },
    },
    {
      "name": "vidra (profile mode)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "profile",
      "env": {
        "SERIOUS_PYTHON_SITE_PACKAGES": "${workspaceFolder}/.serious_python/site-packages",
        "SERIOUS_PYTHON_APP": "${workspaceFolder}/.serious_python/app",
      },
    },
    {
      "name": "vidra (release mode)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "env": {
        "SERIOUS_PYTHON_SITE_PACKAGES": "${workspaceFolder}/.serious_python/site-packages",
        "SERIOUS_PYTHON_APP": "${workspaceFolder}/.serious_python/app",
      },
    },
  ]
}